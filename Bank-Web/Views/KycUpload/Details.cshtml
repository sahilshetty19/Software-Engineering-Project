@model Bank.Web.Models.KycUploadDetails

@{
    ViewData["Title"] = "KYC Upload Details";

    var pscFront = Model.Images?.FirstOrDefault(x => x.DocumentType == Bank.Web.Models.DocumentType.PSCFront);
    var pscBack = Model.Images?.FirstOrDefault(x => x.DocumentType == Bank.Web.Models.DocumentType.PSCBack);

    var pscFrontOk = (pscFront?.IsImageValidated == true);
    var pscBackOk = (pscBack?.IsImageValidated == true);
    var imagesValidated = pscFrontOk && pscBackOk;

    var dedupeExecuted = Model.DedupeExecuted;
    var dedupePassed = Model.DedupePassed;

    var searchExecuted = Model.SearchExecuted;
    var searchFound = Model.SearchFound;
    var hasCkycNumber = !string.IsNullOrWhiteSpace(Model.CkycNumber);
    var status = Model.Status;

    var canCheckDedupe = imagesValidated;

    var canSearchCkyc = imagesValidated && dedupeExecuted && dedupePassed == false;

    var canDownload = imagesValidated && dedupeExecuted && dedupePassed == false && searchExecuted == true && searchFound == true && hasCkycNumber;

    var canGenerateZip =
        imagesValidated &&
        dedupePassed == false &&
        searchExecuted == true &&
        searchFound == false &&
        status != Bank.Web.Models.KycWorkflowStatus.Zipped &&
        status != Bank.Web.Models.KycWorkflowStatus.Sent &&
        status != Bank.Web.Models.KycWorkflowStatus.Completed &&
        status != Bank.Web.Models.KycWorkflowStatus.KycDone;

    var canSendToSftp = status == Bank.Web.Models.KycWorkflowStatus.Zipped || status == Bank.Web.Models.KycWorkflowStatus.Failed;
    var canCheckStatus = status == Bank.Web.Models.KycWorkflowStatus.Sent;

    var canDecryptDownload =
        hasCkycNumber &&
        Model.CkycDownloadedAtUtc != null;

    var canPushToInternal =
        imagesValidated &&
        hasCkycNumber &&
        (
            (searchFound == true && Model.CkycDownloadedAtUtc != null) ||
            (searchFound == false && (status == Bank.Web.Models.KycWorkflowStatus.Completed || status == Bank.Web.Models.KycWorkflowStatus.KycDone))
        );
   

}

<h2>KYC Upload Details</h2>

@if (TempData["Error"] != null)
{
    <div style="padding:10px;border:1px solid #c00;background:#ffecec;margin:10px 0;">
        @TempData["Error"]
    </div>
}
@if (TempData["Info"] != null)
{
    <div style="padding:10px;border:1px solid #0a0;background:#eaffea;margin:10px 0;">
        @TempData["Info"]
    </div>
}

<div style="margin:10px 0;">
    @if (canCheckDedupe)
    {
        <form asp-action="CheckDedupe" method="post" style="display:inline;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.KycUploadId" />
            <button type="submit">Check Dedupe</button>
        </form>
    }

    @if (canSearchCkyc)
    {
        <form asp-action="SearchCkyc" method="post" style="display:inline;margin-left:6px;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.KycUploadId" />
            <button type="submit">Search CKYC</button>
        </form>
    }
    

    @if (canDownload)
    {
        <form asp-action="DownloadFromCkyc" method="post" style="display:inline;margin-left:6px;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.KycUploadId" />
            <button type="submit">Download CKYC Record</button>
        </form>
    }
    @if (canDecryptDownload)
    {
        <form asp-action="DecryptLatestDownloadResponse" method="post" style="display:inline;margin-left:6px;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.KycUploadId" />
            <button type="submit">Decrypt Download</button>
        </form>
    }
    @if (canGenerateZip)
    {
        <form asp-action="GenerateZip" method="post" style="display:inline;margin-left:6px;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.KycUploadId" />
            <button type="submit">Generate ZIP</button>
        </form>
    }
    @if (canSendToSftp)
    {
        <form asp-action="SendZipToSftp" method="post" style="display:inline;margin-left:6px;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.KycUploadId" />
            <button type="submit">Send ZIP to SFTP</button>
        </form>
    }

    

    @if (canCheckStatus)
    {
        <form asp-action="CheckCkycStatus" method="post" style="display:inline;margin-left:6px;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.KycUploadId" />
            <button type="submit">Check CKYC Status</button>
        </form>
    }

    @if (canPushToInternal)
    {
        <form asp-action="PushToInternal" method="post" style="display:inline;margin-left:6px;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.KycUploadId" />
            <button type="submit">Push to Bank Records</button>
        </form>
    }
</div>

<hr />

<p><b>RequestRef:</b> @Model.RequestRef</p>

@if (Model.DedupeExecuted)
{
    if (Model.DedupePassed == true)
    {
        <p><b>Dedupe Result:</b> PASS (Customer already exists in bank records)</p>
        if (!string.IsNullOrWhiteSpace(Model.DedupeMessage))
        {
            <p><b>Dedupe Message:</b> @Model.DedupeMessage</p>
        }
    }
    else if (Model.DedupePassed == false)
    {
        <p><b>Dedupe Result:</b> FAIL (Customer not found in bank records)</p>
        if (!string.IsNullOrWhiteSpace(Model.DedupeMessage))
        {
            <p><b>Dedupe Message:</b> @Model.DedupeMessage</p>
        }
    }
}

@if (searchExecuted == true)
{
    if (searchFound == true)
    {
        <p><b>CKYC Search Result:</b> Found</p>
    }
    else if (searchFound == false)
    {
        <p><b>CKYC Search Result:</b> Not found</p>
    }
}

@if (hasCkycNumber)
{
    <p><b>CKYC Number:</b> @Model.CkycNumber</p>
}

<p><b>Name:</b> @Model.FirstName @Model.MiddleName @Model.LastName</p>
<p><b>DOB:</b> @Model.DateOfBirth</p>
<p><b>PPSN:</b> @Model.PPSN</p>
<p><b>Email:</b> @Model.Email</p>
<p><b>Phone:</b> @Model.Phone</p>
<p><b>County:</b> @Model.County?.CountyName</p>
<p><b>City:</b> @Model.City?.CityName</p>
<p><b>Status:</b> @Model.Status</p>

@if (Model.CkycDownloadedAtUtc != null)
{
    <p><b>Downloaded From CKYC At:</b> @Model.CkycDownloadedAtUtc</p>
}

<hr />

<h3>PSC Documents</h3>

@if (pscFront == null && pscBack == null)
{
    <p>No PSC documents uploaded.</p>
}
else
{
    <div style="display:flex;gap:24px;flex-wrap:wrap;">
        @if (pscFront != null)
        {
            <div style="border:1px solid #ddd;padding:12px;max-width:420px;">
                <div style="font-weight:600;margin-bottom:8px;">PSC Front</div>

                <div style="margin-bottom:8px;">
                    <img src="@Url.Action("Document", "KycUpload", new { id = pscFront.KycUploadImageId })"
                         style="max-width:400px;max-height:260px;border:1px solid #ccc;"
                         alt="PSC Front" />
                </div>

                @if (!string.IsNullOrWhiteSpace(pscFront.OcrText))
                {
                    <div style="margin:10px 0;">
                        <div style="font-weight:600;margin-bottom:6px;">PSC Front OCR (temporary)</div>
                        <pre style="white-space:pre-wrap;max-height:220px;overflow:auto;border:1px solid #ddd;padding:10px;background:#fafafa;margin:0;">@pscFront.OcrText</pre>
                        <div style="margin-top:6px;font-size:12px;color:#555;">
                            <b>Confidence:</b> @pscFront.OcrConfidence
                        </div>
                    </div>
                }

                <div style="font-size:12px;color:#555;margin-bottom:8px;">
                    <div><b>File:</b> @pscFront.FileName</div>
                    <div><b>Validated:</b> @(pscFront.IsImageValidated ? "Yes" : "No")</div>
                    @if (!string.IsNullOrWhiteSpace(pscFront.ImageValidationMessage))
                    {
                        <div><b>Message:</b> @pscFront.ImageValidationMessage</div>
                    }
                </div>

                <form asp-action="ValidatePscFront" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.KycUploadId" />
                    <button type="submit">Validate PSC Front</button>
                </form>
            </div>
        }

        @if (pscBack != null)
        {
            <div style="border:1px solid #ddd;padding:12px;max-width:420px;">
                <div style="font-weight:600;margin-bottom:8px;">PSC Back</div>

                <div style="margin-bottom:8px;">
                    <img src="@Url.Action("Document", "KycUpload", new { id = pscBack.KycUploadImageId })"
                         style="max-width:400px;max-height:260px;border:1px solid #ccc;"
                         alt="PSC Back" />
                </div>

                <div style="font-size:12px;color:#555;margin-bottom:8px;">
                    <div><b>File:</b> @pscBack.FileName</div>
                    <div><b>Validated:</b> @(pscBack.IsImageValidated ? "Yes" : "No")</div>
                    @if (!string.IsNullOrWhiteSpace(pscBack.ImageValidationMessage))
                    {
                        <div><b>Message:</b> @pscBack.ImageValidationMessage</div>
                    }
                </div>

                <form asp-action="ValidatePscBack" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.KycUploadId" />
                    <button type="submit">Validate PSC Back</button>
                </form>
            </div>
        }
    </div>
}
